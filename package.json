{
  "name": "psychogeo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.4.0",
  "main": "src/start.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "buffer": "^6.0.3",
    "delaunator": "^5.1.0",
    "dotenv": "^17.4.0",
    "electron": "^41.1.1",
    "express": "^5.2.1",
    "geodesy": "^2.4.0",
    "geojson": "^0.5.0",
    "geotiff": "^3.0.5",
    "http-proxy": "^1.18.1",
    "leva": "^0.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shpjs": "^6.2.0",
    "three": "^0.183.2",
    "three-stdlib": "^2.36.1"
  },
  "scripts": {
    "build:shp-wasm": "wasm-pack build rust/shp_processor_wasm --target web --out-dir pkg --out-name shp_processor_wasm",
    "build:shp-wasm:dev": "wasm-pack build rust/shp_processor_wasm --target web --dev --out-dir pkg --out-name shp_processor_wasm",
    "predev": "pnpm run build:shp-wasm:dev",
    "dev": "vite",
    "predev:web": "pnpm run build:shp-wasm:dev",
    "dev:web": "vite",
    "dev:proxy": "node src/start-server",
    "dev:electron": "node src/start-react --trace-warnings",
    "prebuild": "pnpm run build:shp-wasm",
    "start": "vite",
    "build": "vite build",
    "pretypecheck": "pnpm run build:shp-wasm:dev",
    "test": "pnpm run typecheck",
    "electron": "electron .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/delaunator": "^5.0.3",
    "@types/geodesy": "^2.2.8",
    "@types/geojson": "^7946.0.7",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/shpjs": "^3.4.7",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
